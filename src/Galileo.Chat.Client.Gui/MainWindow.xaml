<Window x:Class="Galileo.Chat.Client.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepChat" Height="640" Width="940"
        MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="18,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔒" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="DeepChat" Style="{StaticResource HeaderText}" FontSize="18" VerticalAlignment="Center" />
                <TextBlock Text="chat interno na LAN · ponta a ponta"
                           Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="12,2,0,0" />
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="1" Content="{Binding Current}" />
    </Grid>
</Window>
