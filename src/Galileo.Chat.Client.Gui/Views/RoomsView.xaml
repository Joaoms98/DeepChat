<UserControl x:Class="Galileo.Chat.Client.Gui.Views.RoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Salas" Style="{StaticResource HeaderText}" />
                <TextBlock Text="{Binding Greeting}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
            </StackPanel>
            <Button Content="Logout" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Command="{Binding LogoutCommand}" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Room list -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                <DockPanel>
                    <Grid DockPanel.Dock="Bottom" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewRoomName, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" />
                        <Button Grid.Column="2" Content="Criar sala" Command="{Binding CreateRoomCommand}" />
                        <Button Grid.Column="4" Content="↻" Command="{Binding RefreshCommand}" ToolTip="Atualizar" />
                    </Grid>

                    <ListBox ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}"
                             Margin="6">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name, StringFormat=#{0}}" Padding="6,4" FontSize="14" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Unlock panel -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                    Padding="20" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Abrir sala" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Selecione uma sala e informe a passphrase combinada offline."
                               Style="{StaticResource MutedText}" Margin="0,4,0,16" />

                    <TextBlock Text="Passphrase" Margin="0,0,0,4" />
                    <PasswordBox x:Name="PassphraseInput" />

                    <Button Content="Entrar na sala" Style="{StaticResource AccentButton}" Margin="0,16,0,0"
                            Command="{Binding EnterRoomCommand}" IsDefault="True" />

                    <TextBlock Text="{Binding Status}" Margin="0,16,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
