<UserControl x:Class="Galileo.Chat.Client.Gui.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:inf="clr-namespace:Galileo.Chat.Client.Gui.Infrastructure">
    <UserControl.Resources>
        <inf:KindToBrushConverter x:Key="KindToBrush" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding RoomTitle}" Style="{StaticResource HeaderText}" FontSize="18" />
                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="10" Padding="8,2"
                        Margin="12,2,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConnectionStatus}" Style="{StaticResource MutedText}" />
                </Border>
            </StackPanel>
            <Button Content="Sair da sala" HorizontalAlignment="Right" Command="{Binding LeaveCommand}" />
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                <ScrollViewer x:Name="MessageScroll" VerticalScrollBarVisibility="Auto" Padding="12">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TimeLabel}"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1" Text="{Binding Sender}" FontWeight="SemiBold"
                                               Foreground="{Binding Kind, Converter={StaticResource KindToBrush}}"
                                               Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding Text}"
                                               Foreground="{Binding Kind, Converter={StaticResource KindToBrush}}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Online roster -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                <DockPanel Margin="12">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Online" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" />
                        <Button Content="↻" HorizontalAlignment="Right" Padding="8,2"
                                Command="{Binding RefreshOnlineCommand}" ToolTip="Atualizar lista" />
                    </Grid>
                    <ListBox ItemsSource="{Binding Online}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding Nickname}" Foreground="{StaticResource TextBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Input -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="InputBox" VerticalContentAlignment="Center"
                     Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SendCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="2" Content="Enviar" Style="{StaticResource AccentButton}"
                    Command="{Binding SendCommand}" />
        </Grid>
    </Grid>
</UserControl>
