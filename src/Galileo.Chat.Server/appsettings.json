{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Persistence": {
    "ConnectionString": "Data Source=deepchat.db;Cache=Shared;Foreign Keys=True",
    "RunMigrationsOnStartup": true,
    "ApplySqlitePragmas": true
  },
  "Network": {
    "AllowedIps": [
      "192.168.0.0/16",
      "10.0.0.0/8"
    ],
    "TrustForwardedHeaders": false,
    "AllowLoopback": true
  },
  "Retention": {
    "MessageTtlHours": 24,
    "PurgeIntervalMinutes": 5,
    "VacuumHourUtc": 3
  },
  "Jwt": {
    "Issuer": "DeepChat.Server",
    "Audience": "DeepChat.Client",
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_via_env_DEEPCHAT_JWT_SECRET_or_appsettings.Production.json",
    "AccessTokenLifetimeHours": 8
  }
}
